{
    "compilerOptions": {
        "target": "es2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "declaration": true,
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "paths": {
            "@cab/messaging": ["../packages/messaging"],
            "@cab/events": ["../packages/events"],
            "@cab/observability": ["../packages/observability"]
        }
    },
    "include": ["src"]
}