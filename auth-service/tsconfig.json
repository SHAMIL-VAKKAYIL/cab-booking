{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration":true,
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@cab/observability":["../packages/observability"],
      "cab/events":["../packages/events"],
      "cab/messaging":["../packages/messaging"]
    }
  },
  "include":["src"]

}